<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tetris</title>

  <style>
    @font-face {
      font-family: "Nes";
      src: url("/nintendo-nes-font.otf") format("opentype");
      font-display: swap;
    }

    :root {
      --bg: #08111a;
      --screen: #0e1a24;
      --panel: #172531;
      --panel-alt: #223543;
      --frame: #314955;
      --frame-dark: #071017;
      --text: #f3f6ea;
      --muted: #9eb2a6;
      --accent: #49f2b8;
      --accent-dark: #12382b;
      --warning: #f5b042;
      --danger: #ff6b6b;
      --shadow: #020406;
      --shell-pad: clamp(10px, 1.5vh, 16px);
      --panel-pad: clamp(9px, 1.2vh, 14px);
      --stack-gap: clamp(8px, 1.2vh, 14px);
      --tight-gap: clamp(6px, 0.9vh, 10px);
    }

    html,
    body {
      height: 100%;
    }

    * {
      box-sizing: border-box;
      image-rendering: pixelated;
    }

    body {
      margin: 0;
      min-height: 100dvh;
      height: 100dvh;
      padding: 8px 10px;
      overflow: hidden;
      color: var(--text);
      font-family: "Nes", monospace;
      user-select: none;
      background: var(--bg);
      display: flex;
      justify-content: center;
      align-items: center;
      line-height: 1.6;
    }

    canvas {
      display: block;
      background: #050b10;
      image-rendering: pixelated;
    }

    .app-shell {
      width: min(1080px, 100%);
      max-height: calc(100dvh - 16px);
      position: relative;
      border: 4px solid var(--frame);
      background: var(--frame-dark);
      box-shadow: 0 0 0 4px #000;
      padding: var(--shell-pad);
      display: flex;
      flex-direction: column;
      transform: scale(var(--app-scale, 1));
      transform-origin: center center;
      transition: transform 120ms ease-out;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: stretch;
      gap: var(--stack-gap);
      margin-bottom: var(--stack-gap);
      flex-shrink: 0;
    }

    .title-block h1 {
      margin: 0;
      font-size: clamp(1.4rem, 3vw, 2.3rem);
      letter-spacing: 0.08em;
      line-height: 1.3;
      color: var(--accent);
      text-shadow: 3px 3px 0 #000;
    }

    .title-block p {
      margin: 8px 0 0;
      color: var(--muted);
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .top-status {
      min-width: min(350px, 100%);
      padding: 10px 12px;
      border: 4px solid var(--frame);
      background: var(--panel);
      box-shadow: inset -4px -4px 0 #0d171e;
      text-align: left;
    }

    .top-status-label {
      color: var(--muted);
      font-size: 0.62rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    #room-info {
      font-size: 0.72rem;
      line-height: 1.7;
      word-break: break-word;
      color: var(--accent);
    }

    .game-layout {
      display: grid;
      grid-template-columns: 200px minmax(220px, 1fr) 200px;
      gap: var(--stack-gap);
      align-items: start;
      flex: 1;
      min-height: 0;
    }

    .ui-panel,
    .side-panel {
      display: flex;
      flex-direction: column;
      gap: var(--stack-gap);
    }

    .side-card,
    .preview-box,
    #remote-wrap {
      background: var(--panel);
      border: 4px solid var(--frame);
      box-shadow: inset -4px -4px 0 #0d171e;
    }

    .side-card {
      padding: var(--panel-pad);
    }

    .panel-title,
    .stat-label {
      margin: 0 0 var(--tight-gap);
      color: var(--muted);
      font-size: 0.62rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .stats-stack {
      display: flex;
      flex-direction: column;
      gap: var(--tight-gap);
    }

    .stat-box {
      padding: 10px;
      border: 3px solid var(--frame);
      background: var(--panel-alt);
      box-shadow: inset -3px -3px 0 #17242d;
    }

    .stat-value {
      font-size: 1rem;
      line-height: 1.4;
      color: var(--accent);
    }

    .status-panel-card .status-list {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 6px;
      width: 100%;
    }

    .status-panel-card .status-item {
      display: flex;
      flex-direction: column;
      gap: 3px;
      align-items: flex-start;
      justify-content: center;
      min-height: 0;
      width: 100%;
      padding: 7px 8px 6px;
      border: 3px solid var(--frame);
      background: var(--panel-alt);
      font-size: 0.6rem;
    }

    .status-panel-card .status-key {
      color: var(--muted);
      font-size: 0.58rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      line-height: 1.2;
      white-space: nowrap;
    }

    .status-panel-card .status-value {
      display: block;
      min-width: 0;
      margin: 0;
      text-align: left;
      line-height: 1.2;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      hyphens: none;
    }

    .status-panel-card #watch-label {
      margin-bottom: 0;
    }

    .status-panel-card .status-list.single-stat {
      grid-template-columns: 1fr;
    }

    .controls-list {
      display: grid;
      gap: 8px;
    }

    .controls-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 9px 10px;
      border: 3px solid var(--frame);
      background: #0d171e;
    }

    .controls-action {
      color: var(--muted);
      font-size: 0.58rem;
      line-height: 1.6;
    }

    .controls-key {
      flex-shrink: 0;
      min-width: 72px;
      padding: 5px 8px;
      border: 3px solid var(--frame);
      background: var(--panel-alt);
      color: var(--accent);
      font-size: 0.56rem;
      text-align: center;
      text-transform: uppercase;
      box-shadow: inset -3px -3px 0 #17242d;
    }

    .center-stage {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--stack-gap);
      min-width: 0;
    }

    .playfield-row {
      width: 100%;
      display: flex;
      justify-content: center;
      align-items: flex-start;
      gap: var(--stack-gap);
      min-width: 0;
    }

    .board-frame {
      width: min(100%, 340px);
      max-width: 340px;
      flex: 0 1 340px;
      padding: 10px;
      border: 4px solid var(--frame);
      background: #13212c;
      box-shadow:
        inset 0 0 0 4px #05080c,
        inset -6px -6px 0 #0a1218;
    }

    .board-head {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      align-items: center;
      margin-bottom: 8px;
      padding: 0 2px;
    }

    .board-title {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .board-title strong {
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .board-title span {
      color: var(--muted);
      font-size: 0.58rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    #matchmaking-status {
      padding: 6px 8px;
      border: 3px solid var(--accent-dark);
      background: #0f231d;
      color: var(--accent);
      font-size: 0.56rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      text-align: right;
      max-width: 140px;
      line-height: 1.6;
    }

    .board-canvas-shell {
      position: relative;
      padding: 8px;
      background: #0b131a;
      border: 4px solid var(--frame);
      box-shadow: inset 0 0 0 4px #05080c;
    }

    #tetris {
      width: min(100%, clamp(180px, 31vh, 240px));
      height: auto;
      margin: 0 auto;
      border: 4px solid #314955;
      background: #050b10;
    }

    #companion-area {
      width: 100%;
      max-width: 340px;
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px;
      border: 4px solid var(--frame);
      background: var(--panel);
      box-shadow: inset -4px -4px 0 #0d171e;
    }

    #companion-gif {
      width: 58px;
      height: 58px;
      object-fit: contain;
      flex-shrink: 0;
      border: 3px solid var(--frame);
      background: #0a1117;
      padding: 4px;
    }

    .companion-copy {
      display: flex;
      flex-direction: column;
      gap: 6px;
      min-width: 0;
    }

    .companion-copy strong {
      font-size: 0.6rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
    }

    #speech-bubble {
      min-height: 36px;
      padding: 8px 10px;
      background: #0d171e;
      border: 3px solid var(--frame);
      font-size: 0.58rem;
      opacity: 0;
      transform: translateY(8px);
      transition: opacity 220ms ease, transform 220ms ease;
      line-height: 1.7;
    }

    .preview-box,
    #remote-wrap {
      padding: var(--panel-pad);
    }

    #remote-wrap {
      width: 160px;
      flex: 0 0 160px;
      box-sizing: border-box;
    }

    .preview-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 10px;
      margin-bottom: 8px;
    }

    .preview-note {
      color: var(--muted);
      font-size: 0.56rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .mini-canvas {
      margin: 0 auto;
      border: 3px solid var(--frame);
      background: #050b10;
      width: auto;
      max-width: 100%;
    }

    #watch-label {
      color: var(--text);
      font-size: 0.6rem;
      line-height: 1.4;
      margin-bottom: 8px;
    }

    #watching-line {
      margin-top: 8px;
      color: var(--muted);
      font-size: 0.56rem;
      line-height: 1.45;
    }

    #overlay {
      position: fixed;
      inset: 0;
      z-index: 10;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px 16px;
      background: rgba(3, 7, 11, 0.9);
      transition: background 180ms ease;
    }

    #overlay.forty-line-results-overlay {
      background: rgba(3, 7, 11, 0.76);
    }

    .menu-card {
      width: min(520px, 100%);
      max-height: min(88vh, 760px);
      overflow-y: auto;
      padding: 18px;
      border: 4px solid var(--frame);
      background: #13212c;
      box-shadow: 0 0 0 4px #000;
    }

    .menu-card h1,
    .menu-card h3 {
      margin: 0;
    }

    body,
    .menu-card,
    .menu-popout,
    .controls-groups,
    #room-list {
      scrollbar-width: thin;
      scrollbar-color: #476675 #0c151d;
    }

    body::-webkit-scrollbar,
    .menu-card::-webkit-scrollbar,
    .menu-popout::-webkit-scrollbar,
    .controls-groups::-webkit-scrollbar,
    .directory-grid::-webkit-scrollbar,
    #room-list::-webkit-scrollbar {
      width: 10px;
      height: 10px;
    }

    body::-webkit-scrollbar-track,
    .menu-card::-webkit-scrollbar-track,
    .menu-popout::-webkit-scrollbar-track,
    .controls-groups::-webkit-scrollbar-track,
    .directory-grid::-webkit-scrollbar-track,
    #room-list::-webkit-scrollbar-track {
      background: #0c151d;
      border-left: 2px solid #17242d;
    }

    body::-webkit-scrollbar-thumb,
    .menu-card::-webkit-scrollbar-thumb,
    .menu-popout::-webkit-scrollbar-thumb,
    .controls-groups::-webkit-scrollbar-thumb,
    .directory-grid::-webkit-scrollbar-thumb,
    #room-list::-webkit-scrollbar-thumb {
      background: linear-gradient(180deg, #365567, #28414f);
      border: 2px solid #0c151d;
      border-radius: 999px;
      transition: background 140ms ease;
    }

    body::-webkit-scrollbar-thumb:hover,
    .menu-card::-webkit-scrollbar-thumb:hover,
    .menu-popout::-webkit-scrollbar-thumb:hover,
    .controls-groups::-webkit-scrollbar-thumb:hover,
    .directory-grid::-webkit-scrollbar-thumb:hover,
    #room-list::-webkit-scrollbar-thumb:hover {
      background: linear-gradient(180deg, #4a7086, #355261);
    }

    body::-webkit-scrollbar-thumb:active,
    .menu-card::-webkit-scrollbar-thumb:active,
    .menu-popout::-webkit-scrollbar-thumb:active,
    .controls-groups::-webkit-scrollbar-thumb:active,
    .directory-grid::-webkit-scrollbar-thumb:active,
    #room-list::-webkit-scrollbar-thumb:active {
      background: linear-gradient(180deg, #58a39f, #3d6c6b);
    }

    .hero-title {
      display: flex;
      flex-direction: column;
      gap: 7px;
      margin-bottom: 14px;
      text-align: left;
    }

    .hero-title h1 {
      font-size: clamp(1.4rem, 4vw, 2.2rem);
      letter-spacing: 0.1em;
      line-height: 1.3;
      color: var(--accent);
      text-shadow: 3px 3px 0 #000;
    }

    .hero-title p {
      margin: 0;
      color: var(--warning);
      font-size: 0.58rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .menu-summary {
      margin-bottom: 14px;
      padding: 14px;
      border: 4px solid var(--frame);
      background: #0d171e;
    }

    .menu-summary-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
      margin-top: 10px;
    }

    .menu-summary-card {
      padding: 10px;
      border: 3px solid var(--frame);
      background: var(--panel-alt);
    }

    .menu-summary-value {
      color: var(--accent);
      font-size: 0.82rem;
      line-height: 1.4;
    }

    .quick-stats-line {
      margin-top: 10px;
      color: var(--muted);
      font-size: 0.56rem;
      line-height: 1.8;
    }

    .room-text {
      margin: 8px 0 0;
      color: var(--muted);
      font-size: 0.58rem;
      line-height: 1.8;
      word-break: break-word;
    }

    .menu-section-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-top: 14px;
    }

    .menu-section {
      min-width: 0;
      padding: 12px;
      border: 3px solid var(--frame);
      background: var(--panel-alt);
      box-shadow: inset -3px -3px 0 #17242d;
      display: grid;
      gap: 10px;
    }

    .menu-actions {
      display: grid;
      gap: 8px;
      grid-template-columns: repeat(auto-fit, minmax(124px, 1fr));
    }

    .forty-line-results-modal {
      display: none;
      flex-direction: column;
      width: min(92vw, calc(84vh * 1.45), 720px);
      max-width: 720px;
      aspect-ratio: 16 / 11;
      max-height: 84vh;
      padding: clamp(18px, 3vh, 28px);
      border: 4px solid var(--frame);
      background:
        linear-gradient(180deg, rgba(28, 46, 58, 0.96), rgba(12, 21, 28, 0.98)),
        #13212c;
      box-shadow:
        0 0 0 4px #000,
        0 24px 48px rgba(0, 0, 0, 0.42);
      overflow: hidden;
      animation: fortyLineResultsEnter 240ms ease-out;
    }

    .forty-line-results-frame {
      flex: 1;
      display: grid;
      grid-template-rows: auto 1fr auto;
      gap: clamp(14px, 2.4vh, 22px);
      min-height: 0;
    }

    .forty-line-results-header {
      display: grid;
      gap: 8px;
      justify-items: center;
      text-align: center;
    }

    .forty-line-results-kicker {
      margin: 0;
      color: var(--warning);
      font-size: clamp(0.5rem, 1vh, 0.62rem);
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }

    .forty-line-results-header h1 {
      margin: 0;
      color: var(--accent);
      font-size: clamp(1.35rem, 3.4vh, 2.3rem);
      letter-spacing: 0.1em;
      line-height: 1.2;
      text-shadow: 3px 3px 0 #000;
    }

    .forty-line-results-subtitle {
      margin: 0;
      color: var(--muted);
      font-size: clamp(0.54rem, 1.1vh, 0.66rem);
      line-height: 1.8;
    }

    .forty-line-results-body {
      min-height: 0;
      display: grid;
      grid-template-rows: 1fr auto;
      gap: clamp(12px, 2vh, 18px);
      align-content: center;
    }

    .forty-line-results-time-card {
      min-height: 0;
      padding: clamp(16px, 2.7vh, 22px);
      border: 4px solid var(--frame);
      background:
        radial-gradient(circle at top, rgba(73, 242, 184, 0.16), transparent 58%),
        #0d171e;
      display: grid;
      place-items: center;
      gap: 10px;
      text-align: center;
      box-shadow: inset -4px -4px 0 #081118;
    }

    .forty-line-results-time {
      color: var(--text);
      font-size: clamp(1.65rem, 5.8vh, 3.4rem);
      line-height: 1.1;
      letter-spacing: 0.08em;
      text-shadow: 4px 4px 0 #000;
    }

    .forty-line-results-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: clamp(10px, 1.7vh, 16px);
    }

    .forty-line-results-stat {
      min-width: 0;
      padding: clamp(12px, 2vh, 18px);
      border: 3px solid var(--frame);
      background: var(--panel-alt);
      display: grid;
      gap: 8px;
      align-content: start;
      box-shadow: inset -3px -3px 0 #17242d;
    }

    .forty-line-results-label {
      color: var(--muted);
      font-size: clamp(0.5rem, 1vh, 0.6rem);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      line-height: 1.5;
    }

    .forty-line-results-value {
      min-width: 0;
      color: var(--text);
      font-size: clamp(0.8rem, 2vh, 1.2rem);
      line-height: 1.5;
      overflow-wrap: anywhere;
    }

    .forty-line-results-value.accent {
      color: var(--accent);
    }

    .forty-line-results-note {
      min-height: 1.8em;
      margin: 0;
      color: var(--muted);
      font-size: clamp(0.5rem, 1vh, 0.62rem);
      line-height: 1.7;
      text-align: center;
    }

    .forty-line-results-actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    @keyframes fortyLineResultsEnter {
      from {
        opacity: 0;
        transform: scale(0.94) translateY(10px);
      }

      to {
        opacity: 1;
        transform: scale(1) translateY(0);
      }
    }

    .btn,
    .tiny-btn {
      appearance: none;
      border: 3px solid #000;
      padding: 11px 12px;
      background: var(--accent);
      color: #04110c;
      font-family: "Nes", monospace;
      font-size: 0.6rem;
      letter-spacing: 0.04em;
      cursor: pointer;
      box-shadow: inset -3px -3px 0 rgba(0, 0, 0, 0.28);
    }

    .btn:hover,
    .tiny-btn:hover {
      background: #67f7c4;
    }

    .btn:disabled,
    .tiny-btn:disabled {
      opacity: 0.55;
      cursor: not-allowed;
    }

    .btn.secondary,
    .tiny-btn.dark {
      background: #2b404e;
      color: var(--text);
      border-color: #000;
    }

    .tiny-btn.danger {
      background: #7a2e2e;
      color: var(--text);
      border-color: #000;
    }

    .tiny-btn.danger:hover {
      background: #974040;
    }

    #primary-btn,
    #start-room-btn,
    #restart-btn {
      width: 100%;
    }

    .menu-section {
      margin-top: 14px;
      padding-top: 14px;
      border-top: 4px solid var(--frame);
    }

    .section-heading {
      display: flex;
      flex-direction: column;
      gap: 4px;
      margin-bottom: 12px;
      text-align: left;
    }

    .section-heading strong {
      font-size: 0.62rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .section-heading span {
      color: var(--muted);
      font-size: 0.58rem;
      line-height: 1.8;
    }

    .menu-popout {
      display: none;
      flex-direction: column;
      width: min(640px, 100%);
      max-height: min(88vh, 760px);
      overflow-y: auto;
      opacity: 0;
      transform: translateY(16px) scale(0.97);
      transition: opacity 180ms ease, transform 180ms ease;
    }

    .menu-popout.is-visible {
      opacity: 1;
      transform: translateY(0) scale(1);
    }

    .menu-popout.is-closing {
      opacity: 0;
      transform: translateY(16px) scale(0.97);
    }

    .modal-topbar {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 14px;
    }

    .modal-topbar .section-heading {
      margin-bottom: 0;
      flex: 1;
    }

    .modal-close {
      flex: 0 0 auto;
      min-width: 88px;
    }

    .mode-switch {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-bottom: 14px;
    }

    .mode-switch-btn {
      width: 100%;
    }

    .mode-switch-btn.is-active {
      background: var(--accent);
      color: #04110c;
    }

    .mode-switch-btn.is-inactive {
      background: #2b404e;
      color: var(--text);
    }

    .bot-mode-grid,
    .difficulty-grid,
    .controls-modal-grid {
      display: grid;
      gap: 10px;
    }

    .difficulty-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .controls-modal-grid {
      grid-template-columns: minmax(0, 1fr);
      align-items: start;
    }

    .mode-option-card {
      padding: 12px;
      border: 3px solid var(--frame);
      background: var(--panel-alt);
      box-shadow: inset -3px -3px 0 #17242d;
    }

    .mode-option-card strong {
      display: block;
      margin-bottom: 6px;
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .mode-option-card p {
      margin: 0 0 10px;
      color: var(--muted);
      font-size: 0.54rem;
      line-height: 1.7;
    }

    .controls-modal-group {
      height: auto;
    }

    .controls-modal-group .controls-list {
      gap: 6px;
    }

    .controls-modal-group .controls-item {
      padding: 8px 9px;
      align-items: center;
    }

    .controls-modal-group .controls-key {
      min-width: 96px;
    }

    .controls-editor {
      display: grid;
      gap: 12px;
    }

    .controls-modal-copy {
      display: grid;
      gap: 6px;
    }

    .controls-modal-copy span {
      color: var(--muted);
      font-size: 0.56rem;
      line-height: 1.7;
    }

    .controls-groups {
      display: grid;
      gap: 10px;
      max-height: min(56vh, 480px);
      overflow-y: auto;
      padding-right: 4px;
    }

    .controls-key-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      background: #203645;
      transition: background 0.14s ease, color 0.14s ease, border-color 0.14s ease;
    }

    .controls-key-btn:hover,
    .controls-key-btn:focus {
      background: #29495c;
      border-color: var(--accent);
      outline: none;
    }

    .controls-key-btn.is-listening {
      background: var(--accent);
      border-color: #b2fff1;
      color: #04110c;
    }

    .controls-footer {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
    }

    .controls-footer-note {
      color: var(--muted);
      font-size: 0.54rem;
      line-height: 1.7;
    }

    .modal-note {
      margin: 0 0 12px;
      color: var(--muted);
      font-size: 0.56rem;
      line-height: 1.7;
    }

    .room-browser-top {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-bottom: 14px;
    }

    .room-browser-top > * {
      min-width: 0;
    }

    .room-browser-top .stack-fields {
      grid-column: 1 / -1;
    }

    .tiny-row {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .stack-fields {
      display: grid;
      gap: 8px;
    }

    .tiny-row .input {
      flex: 1;
      margin: 0;
    }

    .input,
    input[type="range"] {
      width: 100%;
    }

    .input {
      padding: 10px 12px;
      border: 3px solid var(--frame);
      background: #08111a;
      color: var(--text);
      font-family: "Nes", monospace;
      font-size: 0.58rem;
      outline: none;
    }

    .input:focus {
      border-color: var(--accent);
    }

    #room-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
      max-height: 220px;
      overflow-y: auto;
      margin-top: 10px;
      padding-right: 4px;
    }

    .room-card {
      padding: 12px;
      border: 3px solid var(--frame);
      background: var(--panel-alt);
      cursor: pointer;
    }

    .room-card:hover {
      border-color: var(--accent);
    }

    .room-card.selected {
      border-color: var(--warning);
      background: #3a2d16;
    }

    .room-card-top,
    .room-card-bottom {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
    }

    .room-card-top {
      margin-bottom: 8px;
      font-size: 0.58rem;
      color: var(--accent);
    }

    .room-card-bottom {
      color: var(--muted);
      font-size: 0.52rem;
      line-height: 1.6;
    }

    .room-empty {
      padding: 16px 14px;
      border: 3px dashed var(--frame);
      color: var(--muted);
      text-align: center;
      font-size: 0.58rem;
    }

    .results-board {
      display: grid;
      gap: 8px;
      margin-top: 10px;
    }

    .leaderboard-toolbar {
      display: grid;
      gap: 12px;
      margin-bottom: 14px;
    }

    .leaderboard-search {
      margin: 0;
    }

    #leaderboards-panel {
      gap: 0;
      overflow: hidden;
    }

    .leaderboard-tab-bar {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 8px;
      margin-bottom: 12px;
    }

    .leaderboard-tab {
      width: 100%;
      min-height: 58px;
      text-align: center;
      line-height: 1.5;
    }

    .leaderboard-tab.active {
      background: var(--accent);
      color: #04110c;
    }

    .leaderboard-tab.inactive {
      background: #2b404e;
      color: var(--text);
    }

    .leaderboard-meta {
      margin-bottom: 12px;
      color: var(--muted);
      font-size: 0.56rem;
      line-height: 1.7;
    }

    .leaderboard-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      align-content: start;
    }

    .leaderboard-card {
      appearance: none;
      display: flex;
      align-items: center;
      gap: 12px;
      width: 100%;
      padding: 12px;
      border: 3px solid var(--frame);
      background: var(--panel-alt);
      color: var(--text);
      font-family: "Nes", monospace;
      text-align: left;
      cursor: pointer;
      box-shadow: inset -3px -3px 0 #17242d;
      transition: border-color 140ms ease, transform 140ms ease;
    }

    .leaderboard-card:hover {
      border-color: var(--accent);
      transform: translateY(-2px);
    }

    .leaderboard-avatar {
      width: 44px;
      height: 44px;
      flex: 0 0 auto;
      border: 3px solid var(--frame);
      background: #08111a;
      object-fit: cover;
    }

    .leaderboard-card-copy {
      min-width: 0;
      display: grid;
      gap: 4px;
    }

    .leaderboard-card-name {
      min-width: 0;
      font-size: 0.62rem;
      line-height: 1.6;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .leaderboard-card-hint {
      color: var(--muted);
      font-size: 0.5rem;
      line-height: 1.5;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .leaderboard-pagination {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-top: 14px;
    }

    .leaderboard-page-copy {
      color: var(--muted);
      font-size: 0.56rem;
      text-align: center;
      line-height: 1.7;
    }

    .player-profile-popout {
      position: fixed;
      inset: 0;
      z-index: 24;
      display: none;
      pointer-events: none;
    }

    .player-profile-popout.is-open,
    .player-profile-popout.is-closing {
      display: block;
    }

    .player-profile-backdrop {
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity 180ms ease;
      pointer-events: none;
    }

    .player-profile-card {
      position: fixed;
      top: var(--player-profile-top, 50%);
      left: var(--player-profile-left, 50%);
      width: min(360px, calc(100vw - 32px));
      padding: 16px;
      border: 4px solid var(--frame);
      background:
        linear-gradient(180deg, rgba(54, 94, 118, 0.28), transparent 36%),
        #13212c;
      box-shadow: 0 20px 44px rgba(0, 0, 0, 0.38), 0 0 0 4px #000;
      opacity: 0;
      transform: translate3d(var(--player-profile-shift-x, -50%), var(--player-profile-shift-y, -50%), 0) scale(0.96);
      transition: opacity 180ms ease, transform 200ms cubic-bezier(0.22, 1, 0.36, 1);
      pointer-events: auto;
    }

    .player-profile-popout.is-open .player-profile-card {
      opacity: 1;
      transform: translate3d(var(--player-profile-shift-x, -50%), var(--player-profile-shift-y, -50%), 0) scale(1);
    }

    .player-profile-popout.is-closing .player-profile-card {
      opacity: 0;
      transform: translate3d(var(--player-profile-shift-x, -50%), calc(var(--player-profile-shift-y, -50%) + 8px), 0) scale(0.97);
    }

    .player-profile-head {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      margin-bottom: 12px;
    }

    .player-profile-avatar {
      width: 72px;
      height: 72px;
      flex: 0 0 auto;
      border: 4px solid var(--frame);
      background: #08111a;
      object-fit: cover;
    }

    .player-profile-copy {
      min-width: 0;
      flex: 1 1 auto;
      display: grid;
      gap: 5px;
      padding-top: 2px;
    }

    .player-profile-name {
      font-size: 0.76rem;
      line-height: 1.6;
      word-break: break-word;
    }

    .player-profile-id {
      color: var(--muted);
      font-size: 0.54rem;
      line-height: 1.6;
    }

    .player-profile-bio {
      margin: 0 0 14px;
      padding: 10px 11px;
      border: 3px solid #355264;
      background: rgba(8, 17, 26, 0.52);
      color: #d6e5ef;
      font-size: 0.54rem;
      line-height: 1.8;
      min-height: 58px;
    }

    .player-profile-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .player-profile-stat {
      min-height: 82px;
      padding: 10px;
      border: 3px solid var(--frame);
      background: var(--panel-alt);
      display: grid;
      align-content: space-between;
      gap: 8px;
    }

    .player-profile-stat .stat-label {
      margin: 0;
    }

    .player-profile-stat-value {
      color: var(--accent);
      font-size: 0.64rem;
      line-height: 1.6;
      word-break: break-word;
    }

    .player-profile-close {
      align-self: flex-start;
      min-width: 0;
      padding-left: 10px;
      padding-right: 10px;
    }

    @keyframes overlayFadeIn {
      from {
        opacity: 0;
      }

      to {
        opacity: 1;
      }
    }

    @keyframes modalPopIn {
      from {
        opacity: 0;
        transform: scale(0.96);
      }

      to {
        opacity: 1;
        transform: scale(1);
      }
    }

    .leader-row {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 10px;
      align-items: center;
      padding: 10px 12px;
      border: 3px solid var(--frame);
      background: var(--panel-alt);
      font-size: 0.56rem;
    }

    .leader-row.winner {
      border-color: var(--warning);
      background: #3a2d16;
    }

    .leader-row span:last-child {
      color: var(--accent);
    }

    #settings-panel,
    #companion-panel {
      display: none;
      flex-direction: column;
      gap: 14px;
      text-align: left;
    }

    .companion-item {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
      padding: 12px 14px;
      border: 3px solid var(--frame);
      background: var(--panel-alt);
      cursor: pointer;
    }

    .companion-item.active {
      border-color: var(--accent);
      background: #1c3a31;
    }

    .setting-item {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
    }

    .setting-item.ui-scale-setting {
      align-items: center;
      gap: 10px;
    }

    .ui-scale-controls {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
    }

    .ui-scale-value {
      min-width: 52px;
      text-align: center;
      color: var(--accent);
      font-size: 0.6rem;
    }

    .scale-btn {
      min-width: 34px;
      padding: 8px 10px;
      line-height: 1;
    }

    label {
      color: var(--muted);
      font-size: 0.56rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      line-height: 1.6;
    }

    .color-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .settings-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .profile-settings-card,
    .directory-card {
      padding: 12px;
      border: 3px solid var(--frame);
      background: var(--panel-alt);
      box-shadow: inset -3px -3px 0 #17242d;
    }

    .profile-settings-shell,
    .directory-shell {
      display: grid;
      gap: 14px;
    }

    .profile-settings-shell {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: start;
    }

    .profile-settings-shell > .settings-actions,
    .profile-settings-shell > .save-note {
      grid-column: 1 / -1;
    }

    .profile-settings-head {
      display: flex;
      gap: 14px;
      align-items: center;
    }

    .profile-settings-avatar {
      width: 76px;
      height: 76px;
      border: 4px solid var(--frame);
      background: #08111a;
      object-fit: cover;
      flex: 0 0 auto;
    }

    .profile-settings-copy {
      min-width: 0;
      display: grid;
      gap: 6px;
    }

    .profile-settings-copy strong {
      font-size: 0.64rem;
      line-height: 1.6;
    }

    .profile-settings-copy span {
      color: var(--muted);
      font-size: 0.54rem;
      line-height: 1.7;
    }

    textarea.input {
      min-height: 88px;
      resize: vertical;
      line-height: 1.8;
    }

    .field-note,
    .save-note {
      color: var(--muted);
      font-size: 0.52rem;
      line-height: 1.7;
    }

    .save-note {
      min-height: 1.7em;
    }

    .directory-toolbar {
      display: grid;
      gap: 10px;
    }

    .directory-grid {
      display: grid;
      gap: 10px;
      max-height: min(38vh, 320px);
      overflow-y: auto;
      padding-right: 4px;
    }

    .directory-card {
      appearance: none;
      display: flex;
      align-items: flex-start;
      gap: 12px;
      width: 100%;
      color: var(--text);
      font-family: "Nes", monospace;
      text-align: left;
      cursor: pointer;
    }

    .directory-card:hover {
      border-color: var(--accent);
    }

    .directory-avatar {
      width: 50px;
      height: 50px;
      border: 3px solid var(--frame);
      background: #08111a;
      object-fit: cover;
      flex: 0 0 auto;
    }

    .directory-copy {
      min-width: 0;
      display: grid;
      gap: 5px;
      flex: 1 1 auto;
    }

    .directory-name-row {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: baseline;
    }

    .directory-name {
      font-size: 0.62rem;
      line-height: 1.6;
      word-break: break-word;
    }

    .directory-id {
      color: var(--muted);
      font-size: 0.5rem;
      line-height: 1.6;
      flex: 0 0 auto;
    }

    .directory-bio {
      color: var(--muted);
      font-size: 0.52rem;
      line-height: 1.7;
      min-height: 1.7em;
    }

    hr {
      border: 0;
      border-top: 3px solid var(--frame);
      margin: 2px 0;
    }

    @media (max-width: 1020px) {
      .game-layout {
        grid-template-columns: minmax(170px, 1fr) minmax(220px, 300px) minmax(170px, 1fr);
        gap: 12px;
      }
    }

    @media (max-height: 900px) {
      body {
        padding: 6px 8px;
      }

      .app-shell {
        max-height: calc(100dvh - 12px);
      }

      .title-block h1 {
        font-size: clamp(1.2rem, 2.4vw, 1.8rem);
      }

      .title-block p,
      #room-info,
      .board-title strong,
      .board-title span,
      #matchmaking-status,
      .panel-title,
      .stat-label,
      .preview-note,
      .status-item,
      .companion-copy strong,
      #speech-bubble,
      #watch-label,
      #watching-line {
        font-size: 0.52rem;
      }

      .stat-value {
        font-size: 0.86rem;
      }

      .game-layout {
        grid-template-columns: 180px minmax(210px, 1fr) 180px;
      }
    }

    @media (max-height: 780px) {
      .game-layout {
        grid-template-columns: 165px minmax(200px, 1fr) 165px;
      }

      .board-frame,
      #companion-area {
        max-width: 312px;
      }

      #tetris {
        width: min(100%, 170px);
      }

      #remote-board {
        width: 100px;
        height: auto;
      }

      .mini-canvas {
        transform-origin: top center;
      }
    }

    @media (max-width: 860px) {
      body {
        min-height: auto;
        height: auto;
        padding: 18px 12px 26px;
        overflow-y: auto;
        overflow-x: hidden;
        align-items: flex-start;
      }

      .app-shell {
        max-height: none;
      }

      .topbar {
        flex-direction: column;
        align-items: stretch;
      }

      .top-status {
        min-width: 0;
        text-align: left;
      }

      .game-layout {
        grid-template-columns: 1fr;
      }

      .ui-panel,
      .side-panel,
      .center-stage {
        max-width: 360px;
        width: 100%;
        margin: 0 auto;
      }

      .ui-panel {
        order: 2;
      }

      .center-stage {
        order: 1;
      }

      .side-panel {
        order: 3;
      }

      .playfield-row {
        flex-direction: column;
        align-items: center;
      }

      #remote-wrap {
        width: 100%;
        max-width: 340px;
        flex: none;
      }
    }

    @media (max-width: 520px) {
      body {
        padding: 12px 10px 20px;
      }

      .board-frame,
      .menu-card,
      .side-card,
      .preview-box,
      #remote-wrap,
      #companion-area {
        padding-left: 12px;
        padding-right: 12px;
      }

      .board-frame {
        padding: 14px;
      }

      #tetris {
        width: min(100%, 222px);
      }

      #companion-area {
        align-items: flex-start;
      }

      #companion-gif {
        width: 68px;
        height: 68px;
      }

      .tiny-row,
      .settings-actions,
      .menu-section-grid {
        grid-template-columns: 1fr;
        display: grid;
      }

      .profile-settings-shell {
        grid-template-columns: 1fr;
      }

      .room-browser-top {
        grid-template-columns: 1fr;
      }

      .forty-line-results-modal {
        width: min(94vw, calc(86vh * 0.98));
        aspect-ratio: auto;
        max-height: 86vh;
      }

      .forty-line-results-frame {
        grid-template-rows: auto 1fr auto;
      }

      .forty-line-results-grid,
      .forty-line-results-actions,
      .mode-switch,
      .difficulty-grid,
      .controls-modal-grid,
      .player-profile-grid {
        grid-template-columns: 1fr;
      }

      .leaderboard-tab-bar,
      .leaderboard-grid {
        grid-template-columns: 1fr;
      }

      .tiny-btn {
        width: 100%;
      }

      .menu-actions {
        grid-template-columns: 1fr;
      }

      .room-card-top,
      .room-card-bottom {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</head>

<body>
  <div class="app-shell">
    <header class="topbar">
      <div class="title-block">
        <h1>TETRIS</h1>
        <p>Online</p>
      </div>
      <div class="top-status">
        <div class="top-status-label">Current Room</div>
        <div id="room-info">Singleplayer only</div>
      </div>
    </header>

    <main class="game-layout">
      <aside class="ui-panel">
        <section class="side-card">
          <h2 class="panel-title">Run Stats</h2>
          <div class="stats-stack">
            <div class="stat-box">
              <div class="stat-label">Score</div>
              <div id="score" class="stat-value">0</div>
            </div>
            <div class="stat-box">
              <div id="lines-label" class="stat-label">Lines</div>
              <div id="lines" class="stat-value">0</div>
            </div>
            <div class="stat-box">
              <div class="stat-label">Level</div>
              <div id="level" class="stat-value">1</div>
            </div>
            <div class="stat-box">
              <div class="stat-label">Combo</div>
              <div id="combo" class="stat-value">-</div>
            </div>
            <div class="stat-box">
              <div class="stat-label">Mode</div>
              <div id="mode-value" class="stat-value">Singleplayer</div>
            </div>
            <div id="timer-box" class="stat-box" style="display:none;">
              <div class="stat-label">Timer</div>
              <div id="timer-value" class="stat-value">00:00.000</div>
            </div>
          </div>
        </section>
      </aside>

      <section class="center-stage">
        <div class="playfield-row">
          <div class="board-frame">
            <div class="board-head">
            <div class="board-title">
                <strong>Game</strong>
                <span>Solo / Versus / Watch</span>
              </div>
              <div id="matchmaking-status">singleplayer ready</div>
            </div>
            <div class="board-canvas-shell">
              <canvas id="tetris" width="240" height="400"></canvas>
            </div>
          </div>

          <section id="remote-wrap">
            <div class="preview-header">
              <div class="stat-label">Live Feed</div>
            </div>
            <canvas id="remote-board" class="mini-canvas" width="120" height="200"></canvas>
            <div id="watching-line" style="display:none;">Watching only</div>
          </section>
        </div>

        <div id="companion-area">
          <img id="companion-gif" src="fl_chan.gif" alt="">
