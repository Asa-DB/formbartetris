<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tetris</title>
    <style>
        @font-face {
            font-family: "Nes";
            src: url("/nintendo-nes-font.otf") format("opentype");
            font-display: swap;
        }

        :root {
            --bg: #08111a;
            --panel: #172531;
            --panel-alt: #223543;
            --frame: #314955;
            --text: #f3f6ea;
            --muted: #9eb2a6;
            --accent: #49f2b8;
            --accent-2: #f5b042;
        }

        * {
            box-sizing: border-box;
            image-rendering: pixelated;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Nes", monospace;
            background-color: var(--bg);
            color: var(--text);
            display: grid;
            place-items: center;
            padding: 16px;
        }

        .entry-shell {
            width: min(520px, 100%);
            border: 4px solid var(--frame);
            background: #0d171e;
            box-shadow: 0 0 0 4px #000;
            padding: 18px;
        }

        h1 {
            margin: 0 0 10px;
            color: var(--accent);
            font-size: clamp(1.3rem, 4vw, 2rem);
            line-height: 1.4;
            text-shadow: 3px 3px 0 #000;
        }

        .subcopy {
            margin: 0 0 16px;
            color: var(--muted);
            font-size: 0.58rem;
            line-height: 1.8;
            text-transform: uppercase;
        }

        form {
            background-color: var(--panel);
            width: 100%;
            padding: 16px;
            border: 4px solid var(--frame);
        }

        section {
            margin-bottom: 14px;
            text-align: left;
        }

        label {
            color: var(--muted);
            display: block;
            margin-bottom: 8px;
            font-size: 0.58rem;
            line-height: 1.6;
            text-transform: uppercase;
        }

        input {
            width: 100%;
            padding: 10px 12px;
            border: 3px solid var(--frame);
            font-family: "Nes", monospace;
            font-size: 0.58rem;
            color: var(--text);
            background-color: var(--bg);
        }

        input:focus {
            outline: none;
            border-color: var(--accent);
        }

        button {
            width: 100%;
            padding: 12px;
            border: 3px solid #000;
            background-color: var(--accent);
            color: #04110c;
            font-family: "Nes", monospace;
            font-size: 0.6rem;
            cursor: pointer;
            box-shadow: inset -3px -3px 0 rgba(0, 0, 0, 0.28);
        }

        button:hover {
            background-color: #67f7c4;
        }

        .fee-note {
            margin: 14px 0 0;
            color: var(--accent-2);
            font-size: 0.56rem;
            line-height: 1.8;
        }

        .hint {
            color: var(--muted);
        }
    </style>
</head>

<body>
    <div class="entry-shell">
        <h1>TETRIS</h1>
        <p class="subcopy">Enter passcode to start.</p>
        <form action="/submitpage" method="POST">
            <section class="PIN">
                <label for="pin">Passcode</label>
                <input type="password" name="pin" id="pin" required>
            </section>
            <button type="submit">Start Game</button>
        </form>
        <p class="fee-note">Entry fee: <%= entryFee %> digipogs. <span class="hint">Press P to pause in-game.</span></p>
    </div>
</body>

</html>
